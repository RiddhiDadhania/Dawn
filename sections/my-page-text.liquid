<div class="container banner">
  <div class="parent">
  <div class="left-txt">
    <div class="line">
     {% if section.settings.enabletext %}
		<h2 style="text-align: {{section.settings.text_position}}">{{section.settings.textbox1}}</h2>
{% endif %}
      </div>
    </div>
  <div class="right-img"> 

      {%if section.settings.myimage %}
      <img src="{{section.settings.myimage | img_url: '' }}" />
      {% endif %}

	</div>
  </div>
</div> 





{% schema %}
  {
    "name": "custom page text",
    "settings": [
{
		"type" : "text",
       "id" : "textbox1",
       "label" : "Enter Your Text Here",
       "default" : " this is text block "
},
{
		"type" : "checkbox",
       "id" : "enabletext",
       "label" : "Enter Your Text",
       "default" : true
},
{
                    "type":"image_picker",
                    "label":"select image",
                    "id":"myimage"
                },
{
		"type" : "select",
       "id" : "text_position",
       "label" : "Position your text",
		"options": [
		{"value": "left" ,"label": "Left"},
		{"value": "right","label": "Right"}
]
}
],

"presets" : [
    {
      "category":"text",
      "name":"custom page text"
    }
]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}
